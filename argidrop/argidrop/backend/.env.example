# ─── ArgiDrop Backend — Africa-First Configuration ───

PORT=5000
NODE_ENV=development
BACKEND_URL=https://api.argidrop.africa
WEB_URL=https://argidrop.africa
ALLOWED_ORIGINS=https://argidrop.africa,https://admin.argidrop.africa

# Database (Neon.tech)
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/argidrop?sslmode=require

# Auth
JWT_SECRET=change_to_min_32_chars_in_production
JWT_REFRESH_SECRET=change_to_min_32_chars_in_production

# Platform
PLATFORM_COMMISSION=18
DEFAULT_CURRENCY=XOF
DEFAULT_COUNTRY=TG

# ─── PAYMENT PROVIDERS ───

# Flutterwave (primary for francophone Africa)
FLW_PUBLIC_KEY=FLWPUBK-xxx
FLW_SECRET_KEY=FLWSECK-xxx
FLW_ENCRYPTION_KEY=xxx
FLW_WEBHOOK_SECRET_HASH=xxx

# Paystack (for Nigeria)
PAYSTACK_PUBLIC_KEY=pk_live_xxx
PAYSTACK_SECRET_KEY=sk_live_xxx

# Stripe (for enterprise / international customers)
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ─── NOTIFICATIONS ───

# Firebase Cloud Messaging (push)
FCM_SERVER_KEY=your_firebase_key

# Africa's Talking (primary SMS for West Africa)
AT_API_KEY=xxx
AT_USERNAME=your_username
AT_SENDER_ID=ARGIDROP

# Twilio (fallback SMS)
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# SendGrid (email)
SENDGRID_API_KEY=SG.xxx
FROM_EMAIL=noreply@argidrop.africa

# ─── STORAGE ───
AWS_ACCESS_KEY_ID=xxx
AWS_SECRET_ACCESS_KEY=xxx
AWS_REGION=eu-west-3
AWS_S3_BUCKET=argidrop-uploads

# ─── CACHE / QUEUES ───
REDIS_URL=redis://default:xxx@xxx.upstash.io:6379

# ─── MAPS ───
GOOGLE_MAPS_API_KEY=AIzaxxx

# ─── QR SCAN CONFIG ───
PICKUP_GPS_TOLERANCE_M=200
DELIVERY_GPS_TOLERANCE_M=150
PAYMENT_CODE_TTL_MINS=15
PICKUP_CODE_TTL_MINS=120
