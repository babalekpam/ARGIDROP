{
  "name": "argidrop-driver",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "eas:login": "npx --yes eas-cli@latest login",
    "eas:whoami": "npx --yes eas-cli@latest whoami",
    "eas:init": "npx --yes eas-cli@latest init",
    "eas:secret:maptiler": "npx --yes eas-cli@latest secret:create --scope project --name EXPO_PUBLIC_MAPTILER_KEY --type string",
    "eas:device:create": "npx --yes eas-cli@latest device:create",
    "build:preview:android": "npx --yes eas-cli@latest build --platform android --profile preview",
    "build:preview:ios": "npx --yes eas-cli@latest build --platform ios --profile preview",
    "build:preview:all": "npx --yes eas-cli@latest build --platform all --profile preview",
    "build:prod:android": "npx --yes eas-cli@latest build --platform android --profile production",
    "build:prod:ios": "npx --yes eas-cli@latest build --platform ios --profile production",
    "build:prod:all": "npx --yes eas-cli@latest build --platform all --profile production",
    "submit:android": "npx --yes eas-cli@latest submit --platform android --profile production --latest",
    "submit:ios": "npx --yes eas-cli@latest submit --platform ios --profile production --latest",
    "ship:ios": "bash scripts/build-ios.sh",
    "ship:android": "bash scripts/build-android.sh"
  },
  "dependencies": {
    "@expo/metro-runtime": "~57.0.7",
    "@expo/vector-icons": "^15.0.2",
    "@react-navigation/bottom-tabs": "^7.18.13",
    "@react-navigation/native": "^7.3.13",
    "@react-navigation/stack": "^7.10.16",
    "axios": "^1.14.0",
    "expo": "^57.0.8",
    "expo-build-properties": "~57.0.7",
    "expo-camera": "~57.0.3",
    "expo-clipboard": "~57.0.1",
    "expo-constants": "~57.0.7",
    "expo-device": "~57.0.1",
    "expo-file-system": "~57.0.1",
    "expo-font": "~57.0.1",
    "expo-image-picker": "~57.0.6",
    "expo-location": "~57.0.6",
    "expo-notifications": "~57.0.7",
    "expo-secure-store": "~57.0.1",
    "expo-sharing": "~57.0.7",
    "expo-splash-screen": "~57.0.5",
    "expo-status-bar": "~57.0.1",
    "expo-updates": "~57.0.9",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.26.0",
    "react-native-web": "^0.21.2",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.10.0",
    "socket.io-client": "^4.6.1"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0"
  },
  "overrides": {
    "lodash": "^4.17.21",
    "uuid": "^11.0.5"
  }
}
