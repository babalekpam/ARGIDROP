{
  "expo": {
    "name": "ArgiDrop",
    "slug": "argidrop",
    "owner": "argilette",
    "scheme": "argidrop",
    "version": "1.0.5",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "primaryColor": "#1B4332",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.argilette.argidrop.driver",
      "associatedDomains": [
        "applinks:argidrop.com",
        "applinks:www.argidrop.com"
      ],
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "ArgiDrop needs your location to match you with nearby delivery jobs and share your live position with merchants during active deliveries.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "ArgiDrop tracks your location during active shifts so merchants and recipients can see live delivery progress, even when the app is in the background.",
        "NSCameraUsageDescription": "ArgiDrop needs camera access to scan delivery QR codes.",
        "NSPhotoLibraryUsageDescription": "ArgiDrop lets you upload KYC documents and proof-of-delivery photos from your library.",
        "NSPhotoLibraryAddUsageDescription": "ArgiDrop saves delivery receipts to your library when you tap save.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1B4332"
      },
      "package": "com.argilette.argidrop.driver",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "argidrop.com",
              "pathPrefix": "/jobs"
            },
            {
              "scheme": "https",
              "host": "argidrop.com",
              "pathPrefix": "/track"
            },
            {
              "scheme": "https",
              "host": "www.argidrop.com",
              "pathPrefix": "/jobs"
            },
            {
              "scheme": "https",
              "host": "www.argidrop.com",
              "pathPrefix": "/track"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "blockedPermissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "ArgiDrop needs your location to match you with nearby delivery jobs."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "ArgiDrop needs camera access to scan QR codes and capture proof of delivery.",
          "microphonePermission": false
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1B4332"
        }
      ],
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#F7F3EB"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "buildToolsVersion": "36.0.0",
            "ndkVersion": "27.1.12297006"
          }
        }
      ],
      "expo-secure-store",
      "expo-status-bar"
    ],
    "extra": {
      "maptilerKey": {},
      "eas": {
        "projectId": "dcc37e84-6bea-4779-8213-e282b40d1716"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/dcc37e84-6bea-4779-8213-e282b40d1716"
    }
  }
}
